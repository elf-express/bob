{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@elf-express/bob",
  "version": "1.0.0",
  "description": "BOB Tools — 人 ↔ AI ↔ 命令的中間層:專案結構視覺化、指令執行、依賴掃描、AI 標註/執行審計軌跡(本地 Web UI,host tool)",
  "license": "UNLICENSED",
  "author": "elf-express",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22"
  },
  "type": "commonjs",
  "main": "src/server.js",
